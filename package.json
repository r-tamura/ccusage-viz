{
  "name": "ccusage-viz",
  "version": "0.0.1",
  "description": "Visualize ccusage JSON reports (daily/weekly/monthly/blocks) as bar charts in your terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r-tamura/ccusage-viz.git"
  },
  "bin": {
